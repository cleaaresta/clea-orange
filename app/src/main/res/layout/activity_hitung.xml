<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFF0F5"
    tools:context=".pertemuan2.HitungActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❮ Kembali"
            android:textColor="#D81B60"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvTitleSegitiga"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Hitung Luas Segitiga"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FF69B4" />

        <EditText
            android:id="@+id/etAlas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Alas"
            android:inputType="numberDecimal"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp" />

        <EditText
            android:id="@+id/etTinggi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Tinggi"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnHitungLuas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hitung Luas"
                android:backgroundTint="#FFB6C1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/tvHasilLuas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil Luas: -"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D81B60"
                android:layout_marginStart="16dp" />
        </LinearLayout>


        <TextView
            android:id="@+id/tvTitleKubus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Hitung Volume Kubus"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FF69B4"
            android:layout_marginTop="48dp" />

        <EditText
            android:id="@+id/etSisi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Panjang Sisi"
            android:inputType="numberDecimal"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnHitungVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hitung Volume"
                android:backgroundTint="#FFB6C1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/tvHasilVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil Volume: -"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D81B60"
                android:layout_marginStart="16dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>